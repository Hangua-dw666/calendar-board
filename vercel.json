{
  "version": 2,
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" },
    { "src": "frontend/package.json", "use": "@vercel/vite", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path]" },
    { "src": "/((?!api).*)", "dest": "/frontend/$1" }
  ]
}
